# Copy to .env and fill in. DO NOT commit .env.
# These are read by the `dev:api`, `dev:web`, and `db:push` root scripts.

# Backend (api-server)
DATABASE_URL=postgresql://luis@localhost:5432/wweb_dev
SESSION_SECRET=change-me-to-a-long-random-string
API_PORT=3001
WA_SESSIONS_DIR=./.wa-sessions
PUPPETEER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
PUPPETEER_SKIP_DOWNLOAD=1
# Comma-separated origins allowed to call the API in dev. The Vite dev server origin.
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=debug
NODE_ENV=development

# Frontend (vite)
WEB_PORT=3010  # keep out of 3000/3001 to avoid conflict with other local apps
BASE_PATH=/
# If set, Vite dev server proxies /api and /socket.io here (use for local only, leave empty in Replit).
API_PROXY_TARGET=http://localhost:3001
